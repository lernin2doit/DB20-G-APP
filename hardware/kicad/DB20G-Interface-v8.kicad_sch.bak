  ;; =========================================================================
  ;; NETLIST CONNECTIONS (text annotations for ERC/DRC)
  ;; =========================================================================
  ;;
  ;; POWER:
  ;;   J1.VBUS → F1.pin1
  ;;   F1.pin2 → D2.Anode → +5V rail
  ;;   +5V → U4.IN, U1.VCC5, U3.VCC, U3.AVCC, K1.Coil+, R7→LED1
  ;;   U4.OUT → +3V3 rail
  ;;   +3V3 → U1.VCC33, U2.VDD, U2.REGIN, U2.~RST (pull-up)
  ;;
  ;; USB HUB:
  ;;   J1.D+ → U1.UD+ (via R12 pull-up)
  ;;   J1.D- → U1.UD-
  ;;   U1.DD1+ → U2.D+
  ;;   U1.DD1- → U2.D-
  ;;   U1.DD2+ → U3.D+
  ;;   U1.DD2- → U3.D-
  ;;   U1.XI → Y1.pin1, C11.pin1
  ;;   U1.XO → Y1.pin2, C12.pin1
  ;;   C11.pin2, C12.pin2 → GND
  ;;   U1.GANGED → GND (bus-powered mode)
  ;;   U1.SELF_PWR → GND (bus-powered mode)
  ;;
  ;; SERIAL:
  ;;   U2.TXD → J4.TIP (data to radio)
  ;;   U2.RXD ← J4.RING (data from radio)
  ;;   J4.SLEEVE → GND
  ;;
  ;; PTT (TRANSISTOR):
  ;;   U2.RTS → R1 → Q1.Base
  ;;   Q1.Collector → J2.pin4 (PTT line)
  ;;   Q1.Emitter → GND
  ;;
  ;; PTT (RELAY):
  ;;   U2.DTR → R2 → Q2.Base
  ;;   Q2.Collector → K1.Coil(-)
  ;;   Q2.Emitter → GND
  ;;   K1.Coil(+) → +5V
  ;;   K1.NO → J2.pin4 (PTT line)
  ;;   K1.COM → GND
  ;;   D1 across K1 coil (cathode to +5V)
  ;;
  ;; AUDIO RX (Radio SPK → Phone):
  ;;   J2.pin5 (Speaker+) → C9 → R3 → junction
  ;;   junction → U3.MIC_IN
  ;;   junction → R4 → GND
  ;;
  ;; AUDIO TX (Phone → Radio MIC):
  ;;   U3.SPK_L → C10 → R5 → junction
  ;;   junction → J2.pin2 (Microphone)
  ;;   junction → R6 → GND
  ;;
  ;; RJ-45 PASS-THROUGH:
  ;;   J2.pin1 ↔ J3.pin1 (+V)
  ;;   J2.pin2 ↔ J3.pin2 (MIC, tapped for CM108 TX)
  ;;   J2.pin3 ↔ J3.pin3 (GND)
  ;;   J2.pin4 ↔ J3.pin4 (PTT, tapped for Q1/K1)
  ;;   J2.pin5 ↔ J3.pin5 (SPK+, tapped for CM108 RX)
  ;;   J2.pin6 ↔ J3.pin6 (SPK-)
  ;;   J2.pin7 ↔ J3.pin7 (UP)
  ;;   J2.pin8 ↔ J3.pin8 (DOWN)
  ;;
  ;; LEDS:
  ;;   +5V → R7 → LED1(Green) → GND  (Power)
  ;;   PTT_signal → R8 → LED2(Red) → GND  (PTT Active)
  ;;   U3.GPIO4 → R9 → LED3(Yellow) → GND  (Audio)
  ;;   U2.TX_LED → R10 → LED4(Blue) → GND  (Serial)

)
