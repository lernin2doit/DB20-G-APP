			)
			(layer "B.SilkS"
				(type "Bottom Silk Screen")
			)
			(copper_finish "None")
			(dielectric_constraints yes)
		)
		(pad_to_mask_clearance 0)
		(solder_mask_min_width 0.1)
		(allow_soldermask_bridges_in_footprints no)
		(tenting front back)
