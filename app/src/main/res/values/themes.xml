<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Default dark theme -->
    <style name="Theme.DB20GController" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="android:windowBackground">@color/dark_background</item>
    </style>

    <!-- AMOLED true-black theme -->
    <style name="Theme.DB20GController.AMOLED" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/amoled_background</item>
        <item name="colorSurface">@color/amoled_surface</item>
        <item name="android:windowBackground">@color/amoled_background</item>
    </style>

    <!-- Red-light mode for night vision -->
    <style name="Theme.DB20GController.RedLight" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/red_light_primary</item>
        <item name="colorPrimaryVariant">#800000</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/red_light_primary</item>
        <item name="colorSecondaryVariant">#800000</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="android:colorBackground">@color/red_light_background</item>
        <item name="colorSurface">@color/red_light_surface</item>
        <item name="android:windowBackground">@color/red_light_background</item>
        <item name="android:textColorPrimary">@color/red_light_on_surface</item>
        <item name="android:textColorSecondary">@color/red_light_text_secondary</item>
    </style>

    <!-- Follow System theme — no hardcoded backgrounds so DayNight can switch freely -->
    <style name="Theme.DB20GController.System" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
    </style>
</resources>
